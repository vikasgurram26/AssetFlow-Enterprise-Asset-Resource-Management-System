# Copy this file to .env and fill in real values for your environment.
# .env is gitignored — never commit real secrets.

# Set to True only for local development. Must be False (or unset) in
# any environment reachable by untrusted users.
DJANGO_DEBUG=False

# Required when DJANGO_DEBUG=False. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Comma-separated list of hostnames this deployment serves.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
